<!-- Barra fija para Sección 8 -->
<div id="bar-100" class="percentage-bar">
    <div style="font-size: 16px; font-weight: 500; font-family: 'Montserrat', sans-serif;">Porcentaje total <span id="lbl-suma" style="font-size:32px; font-weight:700; margin-left: 20px; color:#FFFFFF;">0%</span></div>
    <div style="font-size: 13px; margin-top:8px; opacity: 0.8; color: #FFFFFF;">La suma de la distribución debe ser exactamente 100%</div>
</div>

<script>
    const sectionsData = {
        1: { title: "Información particular", steps: [1,2,3,4,5,6,7] },
        2: { title: "Datos de cónyuge", steps: [8,9] },
        3: { title: "Datos de hijos", steps: [10] },
        4: { title: "Datos de tus hijos", steps: [11] },
        5: { title: "Dependientes", steps: [12,13] },
        6: { title: "Mascotas y bienes", steps: [14,15,16] },
        7: { title: "Hábitos financieros", steps: [17,18] },
        8: { title: "Hábitos financieros", steps: [19] },
        9: { title: "Hábitos financieros", steps: [20,21] },
        10: { title: "Hábitos protección", steps: [22] },
        11: { title: "Estilo de vida", steps: [23,24,25,26] }
    };

    let estadoCivilGlobal = '';
    let tieneHijosGlobal = '';

    function createOptions(containerId, name, type, options) {
        const container = document.getElementById(containerId);
        let html = '';
        options.forEach(opt => {
            html += `
            <label class="option-box">
                <input type="${type}" name="${name}" value="${opt}" onclick="updateSelected(this)">
                <div class="custom-radio"></div>
                <div>${opt}</div>
            </label>`;
        });
        container.innerHTML = html;
    }

    function updateSelected(input) {
        if(input.type === 'radio') {
            const boxes = document.querySelectorAll(`input[name="${input.name}"]`);
            boxes.forEach(box => box.parentElement.classList.remove('selected'));
        }
        if(input.checked) { input.parentElement.classList.add('selected'); } 
        else { input.parentElement.classList.remove('selected'); }
        
        if(input.name === 'edocivil') estadoCivilGlobal = input.value;
        if(input.name === 'tiene_hijos') tieneHijosGlobal = input.value;
    }

    // Inicializar Opciones
    createOptions('opts_genero', 'genero', 'radio', ['Hombre', 'Mujer', 'Prefiero no responder']);
    createOptions('opts_estudios', 'estudios', 'radio', ['Sin estudios', 'Primaria', 'Secundaria', 'Preparatoria', 'Universidad', 'Posgrado', 'Maestría', 'Doctorado']);
    createOptions('opts_ocupacion', 'ocupacion', 'radio', ['Empleado', 'Pensionado', 'Independiente', 'Negocio propio', 'Empresario', 'Desempleado']);
    createOptions('opts_edocivil', 'edocivil', 'radio', ['Soltero', 'Casado', 'Unión libre', 'Divorciado', 'Viudo']);
    createOptions('opts_genero_pareja', 'genero_pareja', 'radio', ['Hombre', 'Mujer', 'Prefiero no responder']);
    createOptions('opts_tiene_hijos', 'tiene_hijos', 'radio', ['Sí', 'No']);
    createOptions('opts_dependientes', 'dependientes', 'radio', ['No tengo', 'Madre o padre', 'Hermanos', 'Abuelos', 'Tía(o)', 'Sobrina(o)', 'Otro']);
    createOptions('opts_mascotas', 'mascotas', 'radio', ['Sí', 'No']);
    createOptions('opts_auto', 'auto', 'radio', ['Sí', 'No']);
    createOptions('opts_casa', 'casa', 'radio', ['Sí', 'No']);
    createOptions('opts_ingresos', 'ingresos', 'radio', ['$14,999 o menos', '$15,000 - $29,999', '$30,000 - $44,999', '$45,000 - $64,999', '$65,000 - $79,999', '$80,000 - $94,999', '$95,000 - $109,999']);
    createOptions('opts_objetivo_ahorro', 'objetivo_ahorro', 'checkbox', ['Retiro', 'Fondo escolar', 'Viaje', 'Inmuebles', 'Auto', 'Fondo emergencia', 'Emprender negocio']);
    createOptions('opts_hospital', 'hospital', 'radio', ['Hospital Privado', 'Hospital Público']);
    createOptions('opts_enfermedad', 'enfermedad', 'radio', ['Sí', 'No']);
    createOptions('opts_deporte', 'deporte', 'radio', ['Sí, bajo riesgo', 'Sí, alto riesgo', 'No practico deporte']);

    let numHijosUI = 0;
    function agregarHijo() {
        numHijosUI++;
        const container = document.getElementById('hijos_container');
        const div = document.createElement('div');
        div.style.marginBottom = '25px';
        div.innerHTML = `
            <div style="font-weight:700; margin-bottom:12px; color:var(--primary-dark);">Hijo ${numHijosUI}</div>
            <div style="display:flex; gap:15px; margin-bottom:15px;">
                <label class="option-box" style="flex:1;"><input type="radio" name="gh_${numHijosUI}" value="Hombre" onclick="updateSelected(this)"><div class="custom-radio"></div><div>Hombre</div></label>
                <label class="option-box" style="flex:1;"><input type="radio" name="gh_${numHijosUI}" value="Mujer" onclick="updateSelected(this)"><div class="custom-radio"></div><div>Mujer</div></label>
            </div>
            <input type="number" placeholder="Edad actual (años)">
            <hr style="border:0; border-top:1px solid var(--border-color); margin-top:25px;">`;
        container.appendChild(div);
    }
    agregarHijo();

    // Dinámica 100%
    const inputs100 = document.querySelectorAll('.pct-input');
    const lblSuma = document.getElementById('lbl-suma');
    const bar100 = document.getElementById('bar-100');
    inputs100.forEach(input => {
        input.addEventListener('input', () => {
            let total = 0;
            inputs100.forEach(i => total += Number(i.value) || 0);
            lblSuma.innerText = total + '%';
            if (total === 100) {
                bar100.style.backgroundColor = 'var(--completed-green)'; 
            } else {
                bar100.style.backgroundColor = 'var(--primary-dark)'; 
            }
        });
    });

    // Lógica Seguros Ninguno
    function seleccionarNinguno() {
        const isChecked = document.getElementById('chk_ninguno').checked;
        if(isChecked) {
            ['seg_auto','seg_hogar','seg_gmm','seg_mascota','seg_edu','seg_retiro','seg_inv','seg_vida','seg_empresa','chk_imss'].forEach(id => {
                document.getElementById(id).checked = false;
            });
        }
    }

    function startTest() {
        document.getElementById('intro').classList.add('hidden');
        document.getElementById('form-header').classList.remove('hidden');
        goToStep(1);
    }

    function drawDots(sectionId, currentStep) {
        const sec = sectionsData[sectionId];
        const container = document.getElementById('dots-container');
        let html = '';
        for (let i = 0; i < sec.steps.length; i++) {
            let stepNum = sec.steps[i];
            let status = (stepNum < currentStep) ? 'completed' : (stepNum === currentStep ? 'current' : 'pending');
            html += `<div class="dot-container ${status}"><div class="dot ${status}"></div><div class="dot-line"></div></div>`;
        }
        container.innerHTML = html;
        document.getElementById('lbl-seccion').innerText = `ETAPA ${sectionId} DE 11`;
        document.getElementById('lbl-titulo').innerText = sec.title;
    }

    function goToStep(step) {
        if(step === 0) {
            document.getElementById('form-header').classList.add('hidden');
            document.getElementById('intro').classList.remove('hidden');
            document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
            return;
        }
        document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
        const target = document.getElementById('step-' + step);
        target.classList.add('active');
        bar100.style.display = (step === 19) ? 'block' : 'none';
        const section = target.getAttribute('data-section') || 1;
        drawDots(section, step);
        window.scrollTo(0,0);
    }
    
    function nextQuestion(n) { goToStep(n); }
    function evalStep7() { nextQuestion( (estadoCivilGlobal === 'Casado' || estadoCivilGlobal === 'Unión libre') ? 8 : 10 ); }
    function backFromStep10() { nextQuestion( (estadoCivilGlobal === 'Casado' || estadoCivilGlobal === 'Unión libre') ? 9 : 7 ); }
    function evalStep10() { nextQuestion( (tieneHijosGlobal === 'Sí') ? 11 : 12 ); }
    function backFromStep12() { nextQuestion( (tieneHijosGlobal === 'Sí') ? 11 : 10 ); }

    function validar100(next) {
        let total = 0;
        document.querySelectorAll('.pct-input').forEach(i => total += Number(i.value) || 0);
        if(total !== 100) alert('Las respuestas en esta sección deben sumar exactamente el 100%. Por favor ajusta tus porcentajes.');
        else nextQuestion(next);
    }

    function updateCircle(id, percentage) {
        document.getElementById('txt_' + id).innerText = percentage + '%';
        document.getElementById(id).style.background = `conic-gradient(var(--primary-main) ${percentage}%, #F3F4F6 0%)`;
    }

    // ================== LOGICA FINAL ==================
    function finalizar() {
        document.getElementById('form-header').classList.add('hidden');
        document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
        document.getElementById('step-final').classList.add('active');
        window.scrollTo(0,0);

        // Datos Personales
        let genero = document.querySelector('input[name="genero"]:checked')?.value || "Cliente";
        let nac = document.getElementById('q_fecha_nac').value;
        let edad = nac ? (new Date().getFullYear() - new Date(nac).getFullYear()) : 30;
        document.getElementById('perfil_text').innerText = `${genero.toUpperCase()} | ${edad} AÑOS | MÉXICO`;

        // Datos Financieros (Barras)
        let g = Number(document.getElementById('pct_gastos').value) || 0;
        let d = Number(document.getElementById('pct_deudas').value) || 0;
        let a = Number(document.getElementById('pct_ahorro').value) || 0;
        let e = Number(document.getElementById('pct_esparcimiento').value) || 0;
        let t_ahorro = Number(document.getElementById('q_tiempo_ahorro').value) || 0;

        document.getElementById('lbl_bar_gastos').innerHTML = `<span>Gastos Fijos</span> <span>${g}%</span>`;
        document.getElementById('bar_gastos').style.width = g + '%';
        
        document.getElementById('lbl_bar_ahorro').innerHTML = `<span>Ahorro / Inversión</span> <span>${a}%</span>`;
        document.getElementById('bar_ahorro').style.width = a + '%';

        document.getElementById('lbl_bar_tiempo').innerHTML = `<span>Consistencia de Ahorro</span> <span>${t_ahorro} años</span>`;

        document.getElementById('lbl_bar_esparcimiento').innerHTML = `<span>Estilo de Vida</span> <span>${e}%</span>`;
        document.getElementById('bar_esparcimiento').style.width = e + '%';

        // Velocímetro (Salud Financiera)
        let status = "ESTABLE";
        let deg = 0; // centro
        if(g > 60 || d > 30 || a < 5) { 
            status = "VULNERABLE"; 
            deg = -70; 
            document.getElementById('badge_status').style.color = "white";
            document.getElementById('badge_status').style.background = "var(--danger-red)";
        }
        else if (a > 15 && d < 15) { 
            status = "ÓPTIMO"; 
            deg = 70; 
            document.getElementById('badge_status').style.color = "white";
            document.getElementById('badge_status').style.background = "var(--completed-green)";
        } else {
            document.getElementById('badge_status').style.color = "white";
            document.getElementById('badge_status').style.background = "var(--primary-main)";
        }
        
        document.getElementById('badge_status').innerText = status;
        // Animación suave del velocímetro
        setTimeout(() => {
            document.getElementById('needle').style.transform = `translateX(-50%) rotate(${deg}deg)`;
        }, 500);

        // GMM Circulo
        let tieneGMM = document.getElementById('seg_gmm').checked;
        if(tieneGMM) {
            updateCircle('circ_gmm', 8);
            document.getElementById('desc_gmm').innerHTML = "Cuentas con un seguro de <b>Gastos Médicos Mayores</b>. Formas parte del exclusivo 8% de la población asegurada privadamente.";
        } else {
            updateCircle('circ_gmm', 0);
            document.getElementById('desc_gmm').innerHTML = "No detectamos cobertura médica privada. Perteneces al 92% de la población vulnerable a una descapitalización por emergencias de salud.";
        }

        // Ahorro Circulo
        updateCircle('circ_ahorro', a > 0 ? 54 : 10);
        document.getElementById('desc_ahorro').innerHTML = a >= 10 ? `Tu capacidad de ahorro del <b>${a}%</b> te posiciona por encima del promedio nacional.` : `Tu nivel de ahorro es inferior al promedio del 54% de personas en tu estrato socioeconómico.`;

        // Lista de Seguros Contratados
        let htmlSeguros = "";
        let seguros = [
            {id:'seg_auto', name:'Seguro de Auto', sum:'pol_auto'},
            {id:'seg_hogar', name:'Protección Hogar', sum:'pol_hogar'},
            {id:'seg_gmm', name:'Gastos Médicos (GMM)', sum:'pol_gmm'},
            {id:'seg_mascota', name:'Cobertura Mascotas', sum:'pol_mascota'},
            {id:'seg_edu', name:'Fondo Educativo', sum:'pol_edu'},
            {id:'seg_retiro', name:'Plan de Retiro (PPR)', sum:'pol_retiro'},
            {id:'seg_inv', name:'Fondo de Inversión', sum:'pol_inv'},
            {id:'seg_vida', name:'Seguro de Vida', sum:'pol_vida'},
            {id:'seg_empresa', name:'Seguro Empresarial', sum:'pol_empresa'}
        ];

        let contador = 0;
        seguros.forEach(s => {
            if(document.getElementById(s.id).checked) {
                let pol = document.getElementById(s.sum).value || '1';
                htmlSeguros += `<div class="insurance-summary"><b>${s.name}</b> <span>${pol} Póliza(s)</span></div>`;
                contador++;
            }
        });
        if(document.getElementById('chk_imss').checked) {
            htmlSeguros += `<div class="insurance-summary"><b>IMSS / ISSSTE</b> <span style="background:var(--bg-page); color:var(--text-main);">Derechohabiente</span></div>`;
            contador++;
        }
        if(contador === 0) {
            htmlSeguros = `<div style="color:var(--danger-red); font-weight:600; padding: 15px; border: 1px solid #FECACA; background: #FEF2F2; border-radius: 8px;">No se detectaron instrumentos de protección. Patrimonio en riesgo.</div>`;
        }
        document.getElementById('res_seguros_lista').innerHTML = htmlSeguros;

        // Recomendaciones Inteligentes Noctua Capital
        let rec = "";
        let objRetiro = document.getElementById('q_edad_retiro').value || 65;
        
        if(!document.getElementById('seg_retiro').checked) {
            rec += `<li><b>Estrategia de Retiro:</b> Tienes como meta retirarte a los ${objRetiro} años. Te recomendamos redirigir un porcentaje de tu capital de esparcimiento (${e}%) hacia un Plan Personal de Retiro con beneficios fiscales inmediatos.</li>`;
        }
        
        if(!document.getElementById('seg_vida').checked && (tieneHijosGlobal === 'Sí' || estadoCivilGlobal === 'Casado')) {
            rec += `<li><b>Blindaje Patrimonial:</b> Tus dependientes están expuestos financieramente. La estructura de un Seguro de Vida institucional garantizará la continuidad de su estilo de vida y educación.</li>`;
        }

        if(document.getElementById('opts_auto').querySelector('input[value="Sí"]')?.checked && !document.getElementById('seg_auto').checked) {
            rec += `<li><b>Transferencia de Riesgos (Auto):</b> Tu vehículo no cuenta con protección. Un siniestro representa una fuga de capital innecesaria que puede prevenirse con coberturas amplias.</li>`;
        }

        if(rec === "") {
            rec = `<li><b>Mantenimiento de Portafolio:</b> Tu estructura financiera es sólida. El paso sugerido por Noctua Capital es una revisión de sumas aseguradas vs. inflación (UDIS/Dólares) para evitar depreciación de coberturas.</li>`;
        }
        document.getElementById('lista_recomendaciones').innerHTML = rec;
    }
</script>

